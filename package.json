  "scripts": {
    "dev": "next dev",
    "build": "next build && ln -sfn ../../static .next/standalone/.next/static 2>/dev/null; ln -sfn ../../public .next/standalone/public 2>/dev/null; echo ✓ standalone static/public linked",
