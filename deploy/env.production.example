# Portable production environment template
# Copy this file to .env.local on the target host and replace every placeholder.
# Keep real .env.local files out of git/backups shared with others.

# Required: PostgreSQL connection string for Prisma 7 via prisma.config.ts / @prisma/adapter-pg.
# Create the database and user before first deploy, or point to a managed PostgreSQL instance.
DATABASE_URL="REPLACE_WITH_DATABASE_URL"

# Required: random secret, at least 32 bytes. Generate with: openssl rand -base64 48
AUTH_SESSION_SECRET="REPLACE_WITH_RANDOM_SESSION_SECRET_AT_LEAST_32_BYTES"

# Required for first seed/bootstrap only. Use a strong one-time password, then change it in the app.
ADMIN_INITIAL_PASSWORD="REPLACE_WITH_STRONG_ONE_TIME_ADMIN_PASSWORD"

# Public label shown on the login page.
APP_NAME="whrkhldsb"
APP_SLUG="whrkhldsb"
SITE_NAME="VPS 统一管控平台"
AUTH_SESSION_COOKIE_NAME="${APP_SLUG:-whrkhldsb}_session"
NEXT_PUBLIC_APP_PUBLIC_LABEL="your-domain.example"
NEXT_PUBLIC_APP_DESCRIPTION="统一 VPS 管理、审批执行、分布式云盘与媒体浏览平台"

# Next.js binding. Keep HOSTNAME loopback when using Caddy/Nginx on the same host.
HOSTNAME="127.0.0.1"
PORT="3000"

# SSH WebSocket proxy binding. Caddy/Nginx should proxy /ssh to this port.
SSH_WS_HOST="127.0.0.1"
SSH_WS_PORT="3001"
# Recommended production value: https://your-domain.example
SSH_WS_ALLOWED_ORIGINS="https://your-domain.example"

# Runtime data directories on the target host. The installer creates the project-local
# runtime dirs; change these if you want data outside APP_DIR.
STORAGE_ROOT="/var/lib/${APP_SLUG:-whrkhldsb}/storage"
DOWNLOAD_ROOT="/var/lib/${APP_SLUG:-whrkhldsb}/downloads"
BACKUP_DIR="/var/backups/${APP_SLUG:-whrkhldsb}"

# Optional integrations. Leave empty if AList/Emby are not installed on the target host.
ALIST_INTERNAL_URL="http://127.0.0.1:5244"
EMBY_INTERNAL_URL="http://127.0.0.1:8096"

# Production safety: demo fallback is OFF by default. Only set true for isolated local demos.
# PostgreSQL auto-setup (used by install.sh on fresh hosts)
PG_AUTO_SETUP="1"
PG_DB_NAME="whrkhldsb"
PG_DB_USER="whrkhldsb"
PG_DB_PASSWORD=""

ENABLE_DEMO_FALLBACK="false"
AUTH_DEMO_FALLBACK="false"
SERVER_DEMO_FALLBACK="false"
STORAGE_DEMO_FALLBACK="false"
COMMAND_DEMO_FALLBACK="false"
